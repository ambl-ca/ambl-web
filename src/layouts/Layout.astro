---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <div class="flex min-h-screen flex-col">
      <nav
        class="border-primary/30 flex items-center justify-between gap-3 border-b px-6 py-1 sm:px-8"
      >
        <a href="/">
          <img src="/assets/logo.svg" alt="Ambl logo" class="h-10 w-auto" />
        </a>
        <div class="text-sm">
          <a href="/#contact" class="text-primary">GET IN TOUCH</a>
        </div>
      </nav>
      <main class="flex-1 py-10">
        <slot />
      </main>
      <footer class="px-6 py-5 md:px-8">
        <p>🇨🇦 Made in London, Ontario</p>
      </footer>
    </div>
  </body>
</html>

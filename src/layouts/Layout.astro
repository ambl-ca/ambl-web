---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <div class="min-h-screen flex flex-col">
      <nav class="flex items-center gap-3 px-6 py-4 sm:px-10 border-b border-primary/30">
        <a href="/" class="flex items-center">
          <img src="/assets/logo.svg" alt="Ambl logo" class="h-10 w-auto" />
        </a>
      </nav>
      <main class="flex-1 px-6 py-10 sm:px-10">
        <slot />
      </main>
    </div>
  </body>
</html>
